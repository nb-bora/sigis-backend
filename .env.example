# API
SIGIS_ENV=development
SIGIS_API_PREFIX=/v1
SIGIS_CORS_ORIGINS=http://localhost:3000

# Base — défaut SQLite async (dev)
SIGIS_DATABASE_URL=sqlite+aiosqlite:///./sigis.db

