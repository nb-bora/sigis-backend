# Environnement : development | production (production exige SIGIS_SECRET_KEY fort)
SIGIS_ENV=development

# API
SIGIS_API_PREFIX=/v1
# Liste séparée par des virgules (admin local + déploiement Vercel)
SIGIS_CORS_ORIGINS=http://localhost:3000,https://sigis-lime.vercel.app

# Base — défaut SQLite async (dev / tests)
# Par défaut : sigis-backend/sigis.db (ne pas dupliquer d'autres .db dans le dépôt)
# SIGIS_DATABASE_URL=
SIGIS_DATABASE_ECHO=false
# true = create_all au démarrage (dev). false = utiliser Alembic en prod
SIGIS_AUTO_CREATE_TABLES=true

# JWT
SIGIS_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING
SIGIS_JWT_ALGORITHM=HS256
SIGIS_ACCESS_TOKEN_EXPIRE_MINUTES=60
SIGIS_RESET_TOKEN_EXPIRE_MINUTES=30

# E-mail (vide = log console uniquement)
SIGIS_MAIL_SERVER=
SIGIS_MAIL_PORT=587
SIGIS_MAIL_USERNAME=
SIGIS_MAIL_PASSWORD=
SIGIS_MAIL_FROM=noreply@sigis.cm
SIGIS_MAIL_FROM_NAME=SIGIS
SIGIS_MAIL_STARTTLS=true
SIGIS_MAIL_SSL_TLS=false

# Liens dans les e-mails
SIGIS_FRONTEND_URL=http://localhost:3000

# Production PostgreSQL (pip install -e ".[postgres]")
# SIGIS_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/sigis
